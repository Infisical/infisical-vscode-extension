# Infisical AI VS Code Extension - Local Environment Variables
# Copy this file to .env and fill in your values for local development

# VS Code Extension Development
VSCODE_DEBUG_PORT=9229
NODE_ENV=development

# Build Configuration
WEBPACK_MODE=development
SOURCE_MAP=true

# Testing Configuration
TEST_TIMEOUT=30000
TEST_PATTERN=**/*.test.ts

# Optional: Override default Infisical API base URL for development
# INFISICAL_BASE_URL=https://your-custom-infisical-instance.com

# Note: NEVER put actual secrets or credentials in this file
# This is for local development environment variables only
CLAUDE_API_KEY=
