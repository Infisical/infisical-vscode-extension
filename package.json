{
  "name": "infisical",
  "displayName": "Infisical",
  "description": "Browse and manage your Infisical secrets without leaving VS Code.",
  "version": "0.2.0",
  "publisher": "infisical",
  "repository": {
    "type": "git",
    "url": "https://github.com/Infisical/infisical-vscode"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "secrets",
    "security",
    "infisical",
    "environment"
  ],
  "activationEvents": [
    "onView:infisicalSecrets"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "infisical",
          "title": "Infisical",
          "icon": "$(key)"
        }
      ]
    },
    "views": {
      "infisical": [
        {
          "id": "infisicalSecrets",
          "name": "Secrets"
        }
      ]
    },
    "commands": [
      {
        "command": "infisical.login",
        "title": "Login",
        "category": "Infisical",
        "icon": "$(sign-in)"
      },
      {
        "command": "infisical.logout",
        "title": "Logout",
        "category": "Infisical",
        "icon": "$(sign-out)"
      },
      {
        "command": "infisical.refresh",
        "title": "Refresh",
        "category": "Infisical",
        "icon": "$(refresh)"
      },
      {
        "command": "infisical.createSecret",
        "title": "New Secret",
        "category": "Infisical",
        "icon": "$(add)"
      },
      {
        "command": "infisical.updateSecret",
        "title": "Edit Value",
        "category": "Infisical",
        "icon": "$(edit)"
      },
      {
        "command": "infisical.deleteSecret",
        "title": "Delete",
        "category": "Infisical",
        "icon": "$(trash)"
      },
      {
        "command": "infisical.viewSecret",
        "title": "View Secret",
        "category": "Infisical"
      },
      {
        "command": "infisical.openSecretsPanel",
        "title": "Open Secrets Panel",
        "category": "Infisical"
      },
      {
        "command": "infisical.revealValues",
        "title": "Reveal Values",
        "category": "Infisical",
        "icon": "$(eye)"
      },
      {
        "command": "infisical.hideValues",
        "title": "Hide Values",
        "category": "Infisical",
        "icon": "$(eye-closed)"
      },
      {
        "command": "infisical.copySecretValue",
        "title": "Copy Value",
        "category": "Infisical",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "infisical.refresh",
          "when": "view == infisicalSecrets",
          "group": "navigation@1"
        },
        {
          "command": "infisical.login",
          "when": "view == infisicalSecrets && !infisical.authenticated",
          "group": "navigation@2"
        },
        {
          "command": "infisical.logout",
          "when": "view == infisicalSecrets && infisical.authenticated",
          "group": "overflow@1"
        }
      ],
      "view/item/context": [
        {
          "command": "infisical.revealValues",
          "when": "view == infisicalSecrets && viewItem =~ /^infisical\\.(environment|folder)$/",
          "group": "inline@1"
        },
        {
          "command": "infisical.hideValues",
          "when": "view == infisicalSecrets && viewItem =~ /^infisical\\.(environment|folder)\\.revealed$/",
          "group": "inline@1"
        },
        {
          "command": "infisical.createSecret",
          "when": "view == infisicalSecrets && viewItem =~ /^infisical\\.(environment|folder)(\\.revealed)?$/",
          "group": "inline@2"
        },
        {
          "command": "infisical.updateSecret",
          "when": "view == infisicalSecrets && viewItem == infisical.secret",
          "group": "inline@1"
        },
        {
          "command": "infisical.copySecretValue",
          "when": "view == infisicalSecrets && viewItem == infisical.secret",
          "group": "1_copy@1"
        },
        {
          "command": "infisical.updateSecret",
          "when": "view == infisicalSecrets && viewItem == infisical.secret",
          "group": "2_modify@1"
        },
        {
          "command": "infisical.deleteSecret",
          "when": "view == infisicalSecrets && viewItem == infisical.secret",
          "group": "2_modify@2"
        }
      ],
      "commandPalette": [
        {
          "command": "infisical.updateSecret",
          "when": "false"
        },
        {
          "command": "infisical.deleteSecret",
          "when": "false"
        },
        {
          "command": "infisical.viewSecret",
          "when": "false"
        },
        {
          "command": "infisical.copySecretValue",
          "when": "false"
        },
        {
          "command": "infisical.openSecretsPanel",
          "when": "false"
        },
        {
          "command": "infisical.revealValues",
          "when": "false"
        },
        {
          "command": "infisical.hideValues",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Infisical",
      "properties": {
        "infisical.baseUrl": {
          "type": "string",
          "default": "https://us.infisical.com",
          "description": "Infisical API base URL. Set this to your self-hosted instance if you don't use the US or EU regions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "dev": "webpack --mode development",
    "test-compile": "tsc -p ./",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@vscode/test-electron": "^2.3.4",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.47.0",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "vitest": "^1.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "axios": "^1.5.0"
  }
}
